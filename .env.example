# ── Tradovate ──────────────────────────────────────────────
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=

# demo | live  (always start on demo)
TRADOVATE_ENV=demo

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ats_agent

# ── Webhook ────────────────────────────────────────────────
WEBHOOK_SECRET=your_secret_here

# ── MFFU Account Rules ─────────────────────────────────────
ACCOUNT_SIZE=50000
MAX_DRAWDOWN=2000
PROFIT_TARGET=3000
MAX_CONTRACTS=3
RISK_PERCENT=2.0

# ── Strategy ───────────────────────────────────────────────
STRATEGY=1
INSTRUMENT=MESH5
