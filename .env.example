# ── Tradovate ──────────────────────────────────────────────
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=

# demo | live  (always start on demo)
TRADOVATE_ENV=demo

# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ats_agent

# ── Webhook ────────────────────────────────────────────────
WEBHOOK_SECRET=your_secret_here

# ── MFFU Account Rules ─────────────────────────────────────
ACCOUNT_SIZE=50000
MAX_DRAWDOWN=2000
PROFIT_TARGET=3000
MAX_CONTRACTS=2
RISK_PERCENT=1.5

# ── Internal Safety Limits (stricter than MFFU) ────────────
DAILY_LOSS_LIMIT=500
DAILY_PROFIT_TARGET=300
WEEKLY_PROFIT_TARGET=1000
INTERNAL_MAX_DRAWDOWN=1500
TRAILING_DRAWDOWN_SHUTDOWN=True

# ── Strategy ───────────────────────────────────────────────
STRATEGY=1
INSTRUMENT=MESH5
